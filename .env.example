# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=24h

# Supabase Storage
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key
